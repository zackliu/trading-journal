{
  "name": "trading-journal",
  "version": "0.3.0",
  "private": true,
  "description": "Trading Journal — annotated chart-review journal (Option B).",
  "author": "chenyl",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:test",
    "lint": "eslint .",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run build && playwright test",
    "test:package-ai": "node tests/integration/packaged-ai-smoke.mjs",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.5.0",
    "fabric": "^6.9.1",
    "sharp": "^0.35.3",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "canvas": "file:build/stubs/canvas",
    "jsdom": "file:build/stubs/jsdom"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.9",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "canvas": "file:build/stubs/canvas",
    "jsdom": "file:build/stubs/jsdom"
  }
}

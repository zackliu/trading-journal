# fabric declares `canvas` and `jsdom` as optionalDependencies. The Electron
# renderer uses Chromium's native canvas, so node-canvas/jsdom are never used at
# runtime. Skipping optional deps keeps electron-builder's install-app-deps from
# trying to source-compile `canvas` (which needs a Cairo/GTK toolchain and fails
# on CI). better-sqlite3 is a regular dependency and is unaffected.
omit=optional
